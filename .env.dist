POSTGRES_PASSWORD=ogham
OBSIDIAN_API_KEY=REPLACE_WITH_OBSIDIAN_API_KEY

# ── Optional services ──────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_SECRET=REPLACE_WITH_RANDOM_SECRET
LANGFUSE_SALT=REPLACE_WITH_RANDOM_SALT

GRAPHITI_ENABLED=false
NEO4J_PASSWORD=REPLACE_WITH_NEO4J_PASSWORD
# OPENAI_API_KEY — used by Graphiti for entity extraction.
# Shell env takes precedence over .env for Docker Compose.
# Not exported globally by Telamon scripts — only passed to the Graphiti container.
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

DISCORD_BRIDGE_ENABLED=
DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN
DISCORD_ALLOWED_USER_IDS=REPLACE_WITH_DISCORD_USER_IDS

