# ogham global config — written to ~/.ogham/config.env by ogham/install.sh
# ogham v0.9+ uses pydantic-settings; reads this file as global fallback.
# Field names are the pydantic model fields uppercased (DATABASE_BACKEND, etc.)
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://ogham:{{POSTGRES_PASSWORD}}@localhost:17432/ogham
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://localhost:17434
OLLAMA_EMBED_MODEL=nomic-embed-text
DEFAULT_PROFILE={{OGHAM_PROFILE}}
RERANK_ENABLED=true
RERANK_ALPHA=0.55
