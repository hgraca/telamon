{
    "name": "get-e/kata-pokeapi_parser_refactoring",
    "version": "1.0.0",
    "description": "A kata to practice refactoring, tests and polymorphism",
    "license": "MIT",
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "approvals/approval-tests": "dev-Main",
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.9",
        "phpstan/phpstan-phpunit": "^1.3",
        "symplify/easy-coding-standard": "^11.1",
        "symplify/phpstan-extensions": "^11.1"
    },
    "autoload": {
        "psr-4": {
            "Gete\\PokeParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gete\\PokeParser\\Test\\": "tests/"
        }
    },
    "scripts": {
        "app": "./bin/run.php ivysaur bulbasaur pikachu ditto",
        "tests": "phpunit",
        "test-coverage": "phpunit --coverage-html build/coverage",
        "check-cs": "ecs check",
        "fix-cs": "ecs check --fix",
        "phpstan": "phpstan analyse --ansi",
        "dev": [
            "@fix-cs",
            "@phpstan",
            "@tests"
        ]
    }
}
