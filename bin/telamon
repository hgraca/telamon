#!/usr/bin/env bash
# bin/telamon — Global CLI entry point for Telamon

set -euo pipefail

# Portable symlink resolution (macOS BSD readlink has no -f)
_resolve() {
  local p="$1"
  while [ -L "$p" ]; do
    local d; d="$(cd "$(dirname "$p")" && pwd)"
    p="$(readlink "$p")"
    [[ "$p" != /* ]] && p="$d/$p"
  done
  echo "$(cd "$(dirname "$p")" && pwd)/$(basename "$p")"
}

TELAMON_ROOT="$(cd "$(dirname "$(_resolve "${BASH_SOURCE[0]}")")/.." && pwd)"

_usage() {
  cat <<'EOF'
Telamon — Harness for Agentic Software Development

Usage: telamon <command> [args]

Commands:
  up                     Start Telamon services
  down                   Shut down Telamon services
  restart                Restart Telamon services
  status                 Show installation status
  update                 Upgrade all Telamon tools
  doctor                 Run health check
  stats [opts]           Query tool usage statistics (--project, --from, --to, --out)
  init [path]            Initialise a project (default: current dir)
  reset [path]           Remove project wiring, keep data (default: current dir)
  purge [path]           Remove project wiring and data (default: current dir)
  recover-memories [path]  Extract memories from past session transcripts
                           Flags: --all, --full, --dry-run, --batch-size N
  opencode recover         Restore opencode binary from backup
  module add <url-or-path>  Register a module from a git URL or local directory
                           Flags: --name=<name>, --commands=, --agents=, --skills=, --plugins=
  module remove <name>   Remove a registered module by name
  module list            Show all registered modules
  module sync            Re-wire all modules into all initialized projects
  submodule              Deprecated alias for 'module' — use 'telamon module' instead
  uninstall              Completely remove Telamon
  help                   Show this help
EOF
}

CMD="${1:-}"

case "${CMD}" in
  up)        make -C "${TELAMON_ROOT}" up ;;
  down)      make -C "${TELAMON_ROOT}" down ;;
  restart)   make -C "${TELAMON_ROOT}" restart ;;
  status)    make -C "${TELAMON_ROOT}" status ;;
  update)    make -C "${TELAMON_ROOT}" update ;;
  doctor)    make -C "${TELAMON_ROOT}" doctor ;;
  stats)     shift; bash "${TELAMON_ROOT}/src/scripts/stats-query.sh" "$@" ;;
  module)    shift; bash "${TELAMON_ROOT}/bin/module.sh" "$@" ;;
  submodule)
    echo -e "\033[33m⚠  'telamon submodule' is deprecated — use 'telamon module' instead\033[0m" >&2
    shift
    bash "${TELAMON_ROOT}/bin/module.sh" "$@"
    ;;

  recover-memories)
    shift
    bash "${TELAMON_ROOT}/src/scripts/recover-memories.sh" "$@" ;;

  opencode)
    shift
    case "${1:-}" in
      recover)
        BACKUP_DIR="${TELAMON_ROOT}/storage/opencode-backups"
        DEST="${HOME}/.opencode/bin/opencode"
        if [[ ! -d "${BACKUP_DIR}" ]] || [[ -z "$(ls -A "${BACKUP_DIR}" 2>/dev/null)" ]]; then
          echo "No backups found in ${BACKUP_DIR}" >&2; exit 1
        fi
        echo "Available backups:"
        ls -1 "${BACKUP_DIR}" | sed 's/^/  /'
        LATEST="$(ls -1t "${BACKUP_DIR}" | head -1)"
        echo ""
        echo "Restoring latest: ${LATEST}"
        cp "${BACKUP_DIR}/${LATEST}" "${DEST}.new"
        chmod +x "${DEST}.new"
        mv -f "${DEST}.new" "${DEST}"
        echo "✔ Restored ${LATEST} → ${DEST}"
        ;;
      *)
        echo "Usage: telamon opencode recover" >&2; exit 1 ;;
    esac
    ;;

  uninstall) make -C "${TELAMON_ROOT}" uninstall ;;
  init|reset|purge)
    PROJ="${2:-.}"
    [[ "${PROJ}" != /* ]] && PROJ="$(pwd)/${PROJ}"
    make -C "${TELAMON_ROOT}" "${CMD}" "PROJ=${PROJ}" ;;
  help|"") _usage ;;
  *) echo "Error: unknown command '${CMD}'" >&2; echo >&2; _usage >&2; exit 1 ;;
esac
