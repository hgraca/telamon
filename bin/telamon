#!/usr/bin/env bash
# bin/telamon — Global CLI entry point for Telamon

set -euo pipefail

# Portable symlink resolution (macOS BSD readlink has no -f)
_resolve() {
  local p="$1"
  while [ -L "$p" ]; do
    local d; d="$(cd "$(dirname "$p")" && pwd)"
    p="$(readlink "$p")"
    [[ "$p" != /* ]] && p="$d/$p"
  done
  echo "$(cd "$(dirname "$p")" && pwd)/$(basename "$p")"
}

TELAMON_ROOT="$(cd "$(dirname "$(_resolve "${BASH_SOURCE[0]}")")/.." && pwd)"

_usage() {
  cat <<'EOF'
Telamon — Harness for Agentic Software Development

Usage: telamon <command> [args]

Commands:
  up                     Start Telamon services
  down                   Shut down Telamon services
  restart                Restart Telamon services
  status                 Show installation status
  update                 Upgrade all Telamon tools
  doctor                 Run health check
  init [path]            Initialise a project (default: current dir)
  reset [path]           Remove project wiring, keep data (default: current dir)
  purge [path]           Remove project wiring and data (default: current dir)
  recover-memories [path] Recover memories from past sessions (default: current dir)
                          Flags: --all, --full, --dry-run, --batch-size N
  submodule add <url>    Clone a git repo into vendor/ and register in .env
  submodule remove <url> Remove a registered submodule
  submodule list         Show all registered submodules
  uninstall              Completely remove Telamon
  help                   Show this help
EOF
}

CMD="${1:-}"

case "${CMD}" in
  up)        make -C "${TELAMON_ROOT}" up ;;
  down)      make -C "${TELAMON_ROOT}" down ;;
  restart)   make -C "${TELAMON_ROOT}" restart ;;
  status)    make -C "${TELAMON_ROOT}" status ;;
  update)    make -C "${TELAMON_ROOT}" update ;;
  doctor)    make -C "${TELAMON_ROOT}" doctor ;;
  submodule) shift; bash "${TELAMON_ROOT}/bin/submodule.sh" "$@" ;;
  uninstall) make -C "${TELAMON_ROOT}" uninstall ;;
  init|reset|purge)
    PROJ="${2:-.}"
    [[ "${PROJ}" != /* ]] && PROJ="$(pwd)/${PROJ}"
    make -C "${TELAMON_ROOT}" "${CMD}" "PROJ=${PROJ}" ;;
  recover-memories)
    shift  # consume command name

    # Source functions library for config helpers
    INSTALL_PATH="${TELAMON_ROOT}/src/install"
    . "${INSTALL_PATH}/functions/autoload.sh"

    # Parse arguments
    ALL_MODE=false
    FULL_FLAG=""
    DRY_RUN_FLAG=""
    EXTRA_ARGS=()
    PROJ=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --all)        ALL_MODE=true; shift ;;
        --full)       FULL_FLAG="--full"; shift ;;
        --dry-run)    DRY_RUN_FLAG="--dry-run"; shift ;;
        --batch-size) EXTRA_ARGS+=("--batch-size" "$2"); shift 2 ;;
        --db)         EXTRA_ARGS+=("--db" "$2"); shift 2 ;;
        *)            PROJ="$1"; shift ;;
      esac
    done

    _run_recover() {
      local project_dir="$1"

      # Verify project has telamon.ini
      if [[ ! -f "${project_dir}/.ai/telamon/telamon.ini" ]]; then
        warn "${project_dir}: no telamon.ini — skipping (run 'telamon init' first)"
        return 1
      fi

      # Resolve medium_model (lazy prompt if needed)
      local model
      model="$(config.resolve_medium_model "${project_dir}")" || {
        warn "Could not resolve medium_model for ${project_dir}"
        return 1
      }

      # Run Python script
      python3 "${TELAMON_ROOT}/scripts/recover-memories.py" \
        --project "${project_dir}" \
        --model "${model}" \
        ${FULL_FLAG:+"${FULL_FLAG}"} \
        ${DRY_RUN_FLAG:+"${DRY_RUN_FLAG}"} \
        ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}
    }

    if [[ "${ALL_MODE}" == true ]]; then
      # Discover all initialized projects from graphify storage
      PROJECTS=()
      while IFS= read -r _ppath_file; do
        [[ -f "${_ppath_file}" ]] || continue
        _dir="$(cat "${_ppath_file}")"
        [[ -d "${_dir}" ]] || continue
        [[ -f "${_dir}/.ai/telamon/telamon.ini" ]] || continue
        _name="$(config.read_ini "${_dir}/.ai/telamon/telamon.ini" "project_name")" || _name="$(basename "${_dir}")"
        PROJECTS+=("${_dir}|${_name}")
      done < <(find "${TELAMON_ROOT}/storage/graphify" -name ".project-path" 2>/dev/null || true)

      if [[ ${#PROJECTS[@]} -eq 0 ]]; then
        warn "No initialized projects found."
        exit 1
      fi

      # Show list and ask for confirmation
      header "Recover memories — all projects"
      echo ""
      echo "  The following projects will be processed:"
      _idx=1
      for _entry in "${PROJECTS[@]}"; do
        _dir="${_entry%%|*}"
        _name="${_entry##*|}"
        echo "    ${_idx}) ${_name} (${_dir})"
        _idx=$((_idx + 1))
      done
      echo ""
      if [[ -n "${FULL_FLAG}" ]]; then
        echo -e "  ${TEXT_YELLOW}⚠  Mode: FULL RESET — existing memories will be cleared and rebuilt${TEXT_CLEAR}"
        echo ""
      fi

      ask "Proceed? [y/N]:"
      read -r confirm </dev/tty
      if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
        echo "  Cancelled."
        exit 0
      fi
      echo ""

      # Process each project
      FAILED=0
      for _entry in "${PROJECTS[@]}"; do
        _dir="${_entry%%|*}"
        _name="${_entry##*|}"
        header "Processing: ${_name}"
        _run_recover "${_dir}" || FAILED=$((FAILED + 1))
      done

      if [[ ${FAILED} -gt 0 ]]; then
        warn "${FAILED} project(s) had errors."
        exit 1
      fi
    else
      # Single project mode
      if [[ -z "${PROJ}" ]]; then
        PROJ="."
      fi
      [[ "${PROJ}" != /* ]] && PROJ="$(pwd)/${PROJ}"
      PROJ="$(cd "${PROJ}" 2>/dev/null && pwd)" || {
        error "Directory not found: ${PROJ}"
      }

      _run_recover "${PROJ}"
    fi
    ;;
  help|"") _usage ;;
  *) echo "Error: unknown command '${CMD}'" >&2; echo >&2; _usage >&2; exit 1 ;;
esac
