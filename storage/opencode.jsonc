{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "instructions": [
    "AGENTS.md",
    ".ai/context*/*.md"
  ],
  "default_agent": "developer",
  "plugin": [
    "opencode-scheduler",
    ".opencode/plugins/graphify.js",
    ".opencode/plugins/session-capture.js"
  ],
  "permission": {
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "sudo *": "ask"
    },
    "task": "allow",
    "external_directory": "deny",
    "todowrite": "allow",
    "todoread": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "doom_loop": "allow",
    "skill": "allow"
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".cache/**",
      "*no-vcs*",
      "*no-vcs*/**",
      "storage/**",
      ".idea/**",
      ".vscode/**",
      ".env*"
    ]
  },
  "mcp": {
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa",
      "enabled": true,
      "oauth": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "oauth": false
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "oauth": false
    },
    "git": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-v",
        "./:/repo",
        "mcp/git"
      ],
      "enabled": true
    },
    "ast-grep": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-v",
        "./:/app",
        "mcp/ast-grep"
      ],
      "enabled": true
    },
    "ogham": {
      "type": "local",
      "command": [
        "uvx",
        "--with",
        "ogham-mcp[postgres,rerank]",
        "ogham-mcp"
      ],
      "enabled": true,
      "environment": {
        "DATABASE_BACKEND": "postgres",
        "DATABASE_URL": "{file:.ai/adk/secrets/ogham-database-url}",
        "EMBEDDING_PROVIDER": "ollama",
        "OLLAMA_URL": "http://localhost:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "RERANK_ENABLED": "true",
        "RERANK_ALPHA": "0.55"
      }
    },
    "codebase-index": {
      "type": "local",
      "command": [
        "npx",
        "opencode-codebase-index-mcp",
        "--project",
        "."
      ],
      "enabled": true
    },
    "obsidian": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "API_KEY",
        "-e",
        "API_URLS",
        "oleksandrkucherenko/obsidian-mcp:latest"
      ],
      "enabled": true,
      "environment": {
        "API_KEY": "{file:.ai/adk/secrets/obsidian-api-key}",
        "API_URLS": "[\"https://host.docker.internal:27124\"]"
      }
    },
    "qmd": {
      "type": "local",
      "command": [
        "qmd",
        "mcp"
      ],
      "enabled": true,
      // XDG_CACHE_HOME redirects QMD's index and model cache from ~/.cache/qmd/
      // to <adk-root>/storage/qmd/ — consistent with the ADK's storage layout.
      // The path is written to storage/secrets/qmd-cache-home by qmd/install.sh.
      "environment": {
        "XDG_CACHE_HOME": "{file:.ai/adk/secrets/qmd-cache-home}"
      }
    }
  }
}
